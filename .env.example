APP_NAME=Eleven Memory Agent Platform
APP_ENV=dev
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RAG_STORE_DIR=.rag_store
METADATA_DB_PATH=.rag_store/metadata.db
FAISS_INDEX_PATH=.rag_store/faiss.index
FAISS_MAPPING_PATH=.rag_store/faiss_mapping.json
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=.rag_store/models
HYBRID_BM25_ENABLED=true
HYBRID_VECTOR_ENABLED=true
HYBRID_RERANKER_ENABLED=true
HYBRID_BM25_TOP_K=30
HYBRID_VECTOR_TOP_K=30
HYBRID_CANDIDATE_POOL_SIZE=40
HYBRID_BM25_WEIGHT=0.35
HYBRID_VECTOR_WEIGHT=0.25
HYBRID_RERANKER_WEIGHT=0.40
BM25_K1=1.5
BM25_B=0.75
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_CACHE_DIR=.rag_store/models
RERANKER_BATCH_SIZE=8
RERANKER_LOCAL_FILES_ONLY=false
INPUT_GUARD_ENABLED=true
OUTPUT_GUARD_ENABLED=true
HIGH_RISK_ALLOW_LLM=false
AUTHZ_ENABLED=true
AUTHZ_DEFAULT_ALLOW=true
USER_DOC_PERMISSIONS=
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=.rag_store/audit/agent_audit.jsonl
LLM_ENABLED=false
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=mimo-pro
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
MYSQL_DSN=mysql+pymysql://root:password@127.0.0.1:3306/eleven_rag?charset=utf8mb4
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_RECYCLE_SECONDS=3600
MYSQL_POOL_TIMEOUT_SECONDS=30
MYSQL_RETRY_ATTEMPTS=3
MYSQL_RETRY_BACKOFF_SECONDS=0.2
MEMORY_RETRY_ATTEMPTS=3
MEMORY_RETRY_BACKOFF_SECONDS=0.2
MEMORY_OP_ALERT_THRESHOLD_MS=200
MEMORY_FAILURE_ALERT_THRESHOLD=3
MEMORY_MONITOR_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_TTL_SECONDS=86400
SESSION_MAX_MESSAGES=100
PHOENIX_ENDPOINT=http://127.0.0.1:6006
