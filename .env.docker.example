# Optional Docker-specific overrides for `docker compose up`
# Copy to `.env.docker` only when you need to override container defaults.
#
# Notes:
# - Do not repeat MYSQL_DSN / REDIS_URL here unless you intentionally change
#   the compose service topology.
# - By default docker-compose.yml already injects container-safe values for
#   MySQL, Redis and RAG store paths.

APP_NAME=Eleven Memory Agent Platform

# Optional LLM settings
LLM_ENABLED=false
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=mimo-pro
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# Optional retrieval overrides
TOP_K=5
HYBRID_BM25_TOP_K=30
HYBRID_VECTOR_TOP_K=30
HYBRID_CANDIDATE_POOL_SIZE=40
HYBRID_BM25_WEIGHT=0.35
HYBRID_VECTOR_WEIGHT=0.25
HYBRID_RERANKER_WEIGHT=0.40

# Optional guard / authz overrides
AUTHZ_ENABLED=true
AUTHZ_DEFAULT_ALLOW=true
USER_DOC_PERMISSIONS=
INPUT_GUARD_ENABLED=true
OUTPUT_GUARD_ENABLED=true
